{
  "name": "@melvinla/front",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#features/fortnite/hooks/use-stats": {
      "test": "./src/features/fortnite/hooks/use-stats.mock.ts",
      "default": "./src/features/fortnite/hooks/use-stats.tsx"
    },
    "#features/fortnite/backend/get-stats.mock": "./src/features/fortnite/backend/get-stats.mock.ts",
    "#features/fortnite/models": "./src/features/fortnite/models.ts",
    "#storybook/*": "./.storybook/*",
    "#messages/*": "./messages/*",
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.tsx",
      "./src/*/index.ts"
    ]
  },
  "scripts": {
    "predev": "tsx ./scripts/prebuild.ts",
    "dev": "next dev --turbopack",
    "postdev": "tsx ./scripts/postbuild.ts",
    "prebuild": "tsx ./scripts/prebuild.ts",
    "build": "next build",
    "postbuild": "tsx ./scripts/postbuild.ts",
    "start": "next start",
    "check-types": "tsc --noemit",
    "lint": "oxlint . --quiet",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "knip": "knip",
    "i18n:check": "i18n-check --source en --locales ./messages --unused src --reporter table --ignore conway.quoteUrl conway.quoteBy",
    "validate-code": "pnpm run i18n:check && pnpm run knip && pnpm run check-types && pnpm run lint && pnpm run fmt:check",
    "validate-code:fix": "pnpm run lint --fix && pnpm run fmt && pnpm run i18n:check && pnpm run knip && pnpm run check-types",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@heroui/react": "3.0.2",
    "@heroui/styles": "3.0.2",
    "@internationalized/date": "3.12.0",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@sentry/nextjs": "10.47.0",
    "@tanstack/react-query": "5.96.2",
    "@trpc/client": "11.16.0",
    "@trpc/server": "11.16.0",
    "@trpc/tanstack-react-query": "11.16.0",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "@vis.gl/react-google-maps": "1.8.2",
    "city-timezones": "1.3.3",
    "es-toolkit": "1.45.1",
    "lucide-react": "1.7.0",
    "moment-timezone": "0.6.1",
    "motion": "12.38.0",
    "next": "16.2.2",
    "next-intl": "4.9.0",
    "next-mdx-remote": "6.0.0",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "react-syntax-highlighter": "16.1.1",
    "use-debounce": "10.1.1",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.1",
    "@lingual/i18n-check": "0.9.3",
    "@msw/playwright": "0.6.7",
    "@playwright/test": "1.59.1",
    "@storybook/addon-docs": "10.3.4",
    "@storybook/addon-links": "10.3.4",
    "@storybook/addon-themes": "10.3.4",
    "@storybook/nextjs": "10.3.4",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "6.0.1",
    "eslint-plugin-playwright": "2.10.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "gray-matter": "4.0.3",
    "jsdom": "29.0.1",
    "knip": "6.3.0",
    "msw": "2.12.14",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.19.0",
    "postcss": "8.5.8",
    "storybook": "10.3.4",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2",
    "vitest-canvas-mock": "1.1.4"
  },
  "engines": {
    "node": "24.14.1"
  },
  "packageManager": "pnpm@10.33.0",
  "msw": {
    "workerDirectory": [
      "./public"
    ]
  }
}
