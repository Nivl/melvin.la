{
  "name": "@melvinla/front",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "predev": "tsx ./scripts/prebuild.ts",
    "dev": "next dev --turbopack",
    "postdev": "tsx ./scripts/postbuild.ts",
    "prebuild": "tsx ./scripts/prebuild.ts",
    "build": "next build",
    "postbuild": "tsx ./scripts/postbuild.ts",
    "start": "next start",
    "check-types": "tsc --noemit",
    "lint": "eslint --max-warnings=0 .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "oapi-gen": "openapi-typescript ../api/internal/gen/openapi.yml -o ./src/gen/api.d.ts --root-types --root-types-no-schema-prefix",
    "knip": "knip",
    "i18n:check": "i18n-check --source en --locales ./messages --unused src --reporter table --ignore conway.quoteUrl conway.quoteBy",
    "validate-code": "pnpm run i18n:check && pnpm run knip && pnpm run check-types && pnpm run lint",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@heroui/react": "3.0.1",
    "@heroui/styles": "3.0.1",
    "@internationalized/date": "~3.12.0",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@sentry/nextjs": "10.45.0",
    "@tanstack/react-query": "5.91.3",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "@vis.gl/react-google-maps": "1.7.1",
    "city-timezones": "1.3.3",
    "es-toolkit": "1.45.1",
    "lucide-react": "1.6.0",
    "moment-timezone": "0.6.1",
    "motion": "12.38.0",
    "next": "16.2.1",
    "next-intl": "4.8.3",
    "next-mdx-remote": "6.0.0",
    "next-themes": "0.4.6",
    "openapi-fetch": "0.17.0",
    "openapi-react-query": "0.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "react-syntax-highlighter": "16.1.1",
    "use-debounce": "10.1.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.2",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@lingual/i18n-check": "0.9.3",
    "@msw/playwright": "0.6.6",
    "@next/eslint-plugin-next": "16.2.1",
    "@playwright/test": "1.58.2",
    "@storybook/addon-docs": "10.3.1",
    "@storybook/addon-links": "10.3.1",
    "@storybook/addon-themes": "10.3.1",
    "@storybook/nextjs": "10.3.1",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/google.maps": "3.58.1",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-playwright": "2.10.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-storybook": "10.3.1",
    "eslint-plugin-unicorn": "62.0.0",
    "gray-matter": "4.0.3",
    "jsdom": "29.0.1",
    "knip": "6.0.1",
    "msw": "2.12.14",
    "openapi-msw": "2.0.0",
    "openapi-typescript": "7.13.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "storybook": "10.3.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.1",
    "vitest": "4.1.0",
    "vitest-canvas-mock": "1.1.3"
  },
  "imports": {
    "#hooks/fortnite/useStats": {
      "test": "./src/hooks/fortnite/useStats.mock.ts",
      "default": "./src/hooks/fortnite/useStats.tsx"
    },
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.tsx",
      "./src/*/index.ts"
    ]
  },
  "msw": {
    "workerDirectory": [
      "./public"
    ]
  }
}
