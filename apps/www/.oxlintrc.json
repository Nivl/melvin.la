{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["../../.oxlintrc.json"],
  "ignorePatterns": [
    ".next/**",
    "out/**",
    "build/**",
    "next-env.d.ts",
    "public/mockServiceWorker.js",
    "messages/**.ts"
  ],
  "rules": {
    // limit the length of identifiers.
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "next/link",
            "message": "Use \"#i18n/routing\" instead (drop-in replacement)"
          },
          {
            "name": "next/navigation",
            "importNames": ["redirect", "useRouter", "getPathname", "usePathname"],
            "message": "Use \"#i18n/routing\" instead (drop-in replacement)"
          }
        ],
        "patterns": [
          {
            "group": ["#app", "#app/**"],
            "message": "Do not import from src/app. The app/ directory is the Next.js routing layer and must not be imported by other modules."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/app/**/*.tsx"],
      "rules": {
        // off
        "import/no-default-export": "off", // Next.js page/layout files require default exports.
        "no-empty-function": "off", // Next.js routes export empty functions (e.g. generateStaticParams).
        "react/only-export-components": "off" // Next.js route files export non-component values (metadata, config).
      }
    },
    {
      "files": ["e2e/**"],
      "rules": {
        // off
        "import/export": "off", // Playwright fixture files re-export test helpers, triggering false positives.
        "no-empty-pattern": "off", // Playwright fixtures use empty destructuring to opt into fixture context.
        "react/rules-of-hooks": "off", // Not applicable to Playwright test files.
        "vitest/consistent-test-filename": "off", // E2E files use .spec.ts naming, not .test.ts.
        // Custom rules
        "playwright/consistent-spacing-between-blocks": "error", // Enforce blank lines between test/describe blocks.
        "playwright/expect-expect": "error", // Require at least one assertion per test.
        "playwright/max-nested-describe": "error", // Limit nesting depth of describe blocks.
        "playwright/missing-playwright-await": "error", // Require await on async Playwright assertions.
        "playwright/no-conditional-expect": "error", // Prevent conditionally-called assertions.
        "playwright/no-conditional-in-test": "error", // Prevent if/else branching inside tests.
        "playwright/no-duplicate-hooks": "error", // Prevent duplicate beforeEach/afterEach in same scope.
        "playwright/no-duplicate-slow": "error", // Prevent multiple test.slow() calls.
        "playwright/no-element-handle": "error", // Prefer locators over legacy ElementHandle API.
        "playwright/no-eval": "error", // Prevent eval() inside tests.
        "playwright/no-focused-test": "error", // Prevent test.only() from being committed.
        "playwright/no-force-option": "error", // Prevent force: true that bypasses actionability checks.
        "playwright/no-nested-step": "error", // Prevent nesting test.step() calls.
        "playwright/no-networkidle": "error", // Prefer explicit waits over fragile networkidle state.
        "playwright/no-page-pause": "error", // Prevent page.pause() from being committed.
        "playwright/no-skipped-test": "error", // Prevent test.skip() from being committed.
        "playwright/no-standalone-expect": "error", // Prevent assertions outside of test blocks.
        "playwright/no-unsafe-references": "error", // Prevent accessing variables declared in outer test scopes.
        "playwright/no-unused-locators": "error", // Prevent locators that are declared but never used.
        "playwright/no-useless-await": "error", // Prevent unnecessary await on non-Promise values.
        "playwright/no-useless-not": "error", // Prevent double negation (e.g. not.not) in assertions.
        "playwright/no-wait-for-navigation": "error", // Deprecated API; use waitForURL or waitForLoadState instead.
        "playwright/no-wait-for-selector": "error", // Prefer locators over waitForSelector.
        "playwright/no-wait-for-timeout": "error", // Prevent arbitrary timeouts; use explicit condition waits.
        "playwright/prefer-hooks-in-order": "error", // Enforce before* hooks before after* hooks.
        "playwright/prefer-hooks-on-top": "error", // Enforce hooks at the top of describe blocks.
        "playwright/prefer-locator": "error", // Prefer page.locator() over older element query APIs.
        "playwright/prefer-to-have-count": "error", // Prefer toHaveCount() over asserting on length.
        "playwright/prefer-to-have-length": "error", // Prefer toHaveLength() over asserting on length.
        "playwright/prefer-web-first-assertions": "error", // Prefer auto-retrying web-first assertions.
        "playwright/valid-describe-callback": "error", // Ensure describe callbacks are synchronous functions.
        "playwright/valid-expect": "error", // Ensure expect() is called with an assertion matcher.
        "playwright/valid-expect-in-promise": "error", // Require await on expect() inside promise chains.
        "playwright/valid-test-tags": "error", // Ensure test tags are valid strings.
        "playwright/valid-title": "error" // Ensure test and describe titles are non-empty strings.
      },
      "jsPlugins": ["eslint-plugin-playwright"],
      "env": {
        "shared-node-browser": true
      }
    },
    {
      "files": ["src/**/*.mock.ts"],
      "rules": {
        // off
        "import/export": "off" // Mock files re-export module members, triggering false positives.
      }
    },
    {
      "files": ["vitest.setup.ts"],
      "rules": {
        // off
        "jest/no-hooks": "off", // Global vitest setup file legitimately defines beforeAll/afterEach/afterAll for the whole suite.
        "jest/require-top-level-describe": "off", // Global setup file is not a test file; hooks are correctly at module top level.
        "vitest/no-hooks": "off", // Same as jest/no-hooks; see note above.
        "vitest/require-top-level-describe": "off" // Same as jest/require-top-level-describe.
      }
    }
  ]
}
